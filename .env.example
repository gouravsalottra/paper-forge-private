# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── LLM ──────────────────────────────────────────────────────────
# Primary API key used by all agents (SCOUT, QUILL, HAWK, SIGMA, etc.)
OPENAI_API_KEY=sk-...

# Optional: separate key for CODEC Pass 2 to enforce true process isolation.
# If not set, OPENAI_API_KEY is used as fallback.
OPENAI_API_KEY_PASS2=sk-...

# ── Data sources ──────────────────────────────────────────────────
# Set to 'wrds' (default, requires WRDS credentials) or 'yfinance' (dev/demo)
PAPER_FORGE_MINER_SOURCE=wrds

# WRDS credentials (required if PAPER_FORGE_MINER_SOURCE=wrds)
WRDS_USERNAME=your_wrds_username

# ── Modal (FORGE GPU compute) ─────────────────────────────────────
# Modal secret name — store OPENAI_API_KEY inside the Modal secret, not here
MODAL_SECRET_NAME=paper-forge-runtime

# ── Pipeline behaviour ────────────────────────────────────────────
# Override episode count for fast dev/test runs (default: 500000)
# PAPER_FORGE_FORGE_EPISODES=500
